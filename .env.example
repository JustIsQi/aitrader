# Wind MySQL（A 股直读历史行情）
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=winddb
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/winddb?charset=utf8mb4

# 应用持久化（信号 / 回测 / 持仓 / 短线表）；不写默认 sqlite:///aitrader.db
# DATABASE_URL=sqlite:///aitrader.db

# ArXiv pipeline LLM 配置（aitrader.app.cli.arxiv_pipeline 用）
# 优先读这里；不设时回落到 model.py 中 hardcoded 的小蝶 AI gpt-5.4。
LLM_API_KEY=
LLM_BASE_URL=https://api.xiaocaseai.com/v1
LLM_MODEL=gpt-5.4
LLM_TIMEOUT=600
LLM_MAX_TOKENS=32768
LLM_TEMPERATURE=1.0

# docu_assistant PDF 解析（可选，缺省走 pdfplumber）
DOCU_API_URL=
DOCU_API_TOKEN=
DOCU_US3_PREFIX=doc_parser/arxiv_pipeline

# GitHub 集成（可选）
GITHUB_TOKEN=
